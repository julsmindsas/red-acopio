# ---------------------------------------------------------------------------
# Red de Acopio — variables de entorno
# Copia este archivo a `.env.local` y completa los valores que necesites.
# La app funciona SIN configurar nada (usa un store JSON local en desarrollo).
# ---------------------------------------------------------------------------

# Base de datos Postgres (Vercel Postgres / Neon).
# Si está vacía, la app usa el store JSON local (data/centers.local.json).
# En producción (Vercel) define una de estas; la integración de Neon en Vercel
# suele inyectar DATABASE_URL automáticamente.
DATABASE_URL=
POSTGRES_URL=

# API key de Google Maps JavaScript (fallback del mapa).
# OPCIONAL: si está vacía, el fallback a Google queda deshabilitado y la app
# se mantiene en Leaflet + OpenStreetMap. Debe ser una key con la
# "Maps JavaScript API" habilitada. Es pública (NEXT_PUBLIC_*), restríngela por
# dominio en la consola de Google Cloud.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
